{
  "name": "@openchat-server/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push --linked",
    "db:push:local": "supabase db push --local",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff",
    "db:link": "supabase link",
    "db:new-migration": "supabase migration new",
    "db:types": "supabase gen types typescript --local > src/database.types.ts",
    "db:types:linked": "supabase gen types typescript --linked > src/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "supabase": "^2.20.5",
    "typescript": "^5.8.3"
  }
}
